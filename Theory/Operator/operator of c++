int difference = a - b; // Toán tử trừ
int product = a * b; // Toán tử nhân
float division = a / static_cast<float>(b); // Toán tử chia (ép kiểu để có kết quả số thực)
int remainder = a % b; // Toán tử chia lấy phần dư
// toán tử gán
int x = 10;
x += 5; // Tương đương với x = x + 5;
x -= 3; // Tương đương với x = x - 3;
// toán tử tăng/ giảm
int num = 7;
num++; // Tăng giá trị của num lên 1
num--; // Giảm giá trị của num đi 1
// toán tử logic và so sánh 
bool condition1 = true, condition2 = false;
bool result_and = condition1 && condition2; // Toán tử AND logic
bool result_or = condition1 || condition2; // Toán tử OR logic
bool result_not = !condition1; // Toán tử NOT logic

int num1 = 5, num2 = 7;
bool isEqual = (num1 == num2); // So sánh bằng nhau
bool isGreater = (num1 > num2); // So sánh lớn hơn
// toán tử ba ngôi 
int x = 10, y = 20;
int maxNum = (x > y) ? x : y; // Gán giá trị lớn nhất vào maxNum
// toán tử truy cập đối tượng 

struct Point {
    int x;
    int y;
};

int main() {
    Point p;
    p.x = 5; // Toán tử truy cập thành viên đối tượng
    p.y = 10;

    cout << "Point coordinates: " << p.x << ", " << p.y << endl;
    return 0;
}
}